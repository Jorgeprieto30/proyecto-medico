# Base de datos PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=agenda_user
DB_PASSWORD=agenda_pass
DB_DATABASE=agenda_cupos

# Aplicación
APP_PORT=3000
NODE_ENV=development

# Producción (Railway provee DATABASE_URL automáticamente)
# DATABASE_URL=postgresql://user:pass@host:port/db

# CORS - URLs del frontend permitidas (separadas por coma). REQUERIDO en producción.
FRONTEND_URLS=https://tu-app.vercel.app
